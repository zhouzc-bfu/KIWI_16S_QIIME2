一、安装QIIME2-2026.1
# 若conda安装不成功，可尝试memba安装再用conda激活
mamba env create --name qiime2 --file https://raw.githubusercontent.com/qiime2/distributions/refs/heads/dev/2026.1/amplicon/released/qiime2-amplicon-ubuntu-latest-conda.yml
conda activate qiime2
# 因NeSI限制，每次登录终端需要通过source ~/.bashrc手动激活conda base环境
# 另外NeSI限制，screen命令（用于将任务挂后台运行）无法直接使用，可用tmux代替，方法如下：
tmux new -s 111 # 创建名为111的会话
先按下 Ctrl + B，然后松开，再按 D # 脱离会话
tmux attach -t 111 # 重新进入会话

二、制备manifest.tsv文件（该文件是qimme2必须文件，用于告诉软件原始数据名称及存放路径）
# 1. 创建表头
printf "sample-id\tforward-absolute-filepath\treverse-absolute-filepath\n" > manifest.tsv
# 2. 处理 kiwi 文件夹下的数据
for f in kiwi/*forward.fastq.gz; do
    # 提取样本 ID (AG0529-xxxx)
    sample=$(basename "$f" | cut -d'_' -f3)
    r1=$(readlink -f "$f")
    r2=$(readlink -f "${f%.forward.fastq.gz}.reverse.fastq.gz")
    printf "$sample\t$r1\t$r2\n" >> manifest.tsv
done
# 3. 处理 rowi 文件夹下的数据 (排除包含 _PL 的样本)
for f in rowi/*forward.fastq.gz; do
    # 过滤掉包含 _PL 的样本
    if [[ $f == *"_PL"* ]]; then continue; fi
    # 提取样本 ID (rowi_xxx)
    sample=$(basename "$f" | grep -o "rowi_[0-9]\+")
    r1=$(readlink -f "$f")
    r2=$(readlink -f "${f%.forward.fastq.gz}.reverse.fastq.gz")
    printf "$sample\t$r1\t$r2\n" >> manifest.tsv
done

三、导入数据
qiime tools import \
  --type 'SampleData[PairedEndSequencesWithQuality]' \
  --input-path manifest.tsv \
  --output-path kiwi_rowi_combined.qza \
  --input-format PairedEndFastqManifestPhred33V2
